<header class="bg-blue-700 fixed top-0 left-0 right-0 z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center">
                <svg viewBox="0 0 24 24" class="w-5 h-5 text-blue-700" fill="currentColor">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
            </div>
            <span class="text-white font-bold text-lg tracking-tight">RehanSipaOTWKawin</span>
        </div>

        <div class="relative" id="accountWrapper">
            <button id="accountToggle"
                class="flex items-center gap-3 bg-blue-600 hover:bg-blue-500 transition-colors px-3 py-2 rounded-xl">
                <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-700 font-bold text-xs">RM</span>
                </div>
                <div class="hidden sm:block text-left">
                    <p class="text-white text-sm font-semibold leading-none">
                        <%= userName !=='undefined' ? userName : '' %>
                    </p>
                    <p class="text-blue-200 text-xs mt-0.5">
                        <%= shortName !=='undefined' ? shortName : '' %>
                    </p>
                </div>
                <svg id="chevron" class="w-4 h-4 text-blue-200 transition-transform" fill="none" stroke="currentColor"
                    stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </button>

            <div id="dropdown"
                class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 py-1 z-50">
                <a href="#"
                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700">Profil
                    Saya</a>
                <a href="#"
                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700">Pengaturan</a>
                <hr class="my-1 border-gray-100" />
                <a href="/logout"
                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50">Keluar</a>
            </div>
        </div>

    </div>
</header>

<script src="/js/header_dropdown.js"></script>