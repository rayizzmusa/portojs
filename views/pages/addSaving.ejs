<main class="pt-16 min-h-screen bg-white flex items-center justify-center px-6 relative overflow-hidden">

    <!-- Transparent SVG Background -->
    <div class="absolute inset-0">
        <svg viewBox="0 0 1200 700" xmlns="http://www.w3.org/2000/svg" class="w-full h-full"
            preserveAspectRatio="xMidYMid slice">
            <defs>
                <pattern id="dots" width="40" height="40" patternUnits="userSpaceOnUse">
                    <circle cx="20" cy="20" r="1" fill="#1d4ed8" opacity="0.15" />
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dots)" />
            <circle cx="100" cy="120" r="180" fill="#1d4ed8" opacity="0.04" />
            <circle cx="1100" cy="580" r="220" fill="#1d4ed8" opacity="0.04" />
            <circle cx="1050" cy="100" r="120" fill="#1d4ed8" opacity="0.05" />
            <circle cx="200" cy="600" r="150" fill="#1d4ed8" opacity="0.03" />
            <path d="M0 400 Q 300 300 600 400 T 1200 400" stroke="#1d4ed8" stroke-width="1" fill="none" opacity="0.1" />
            <path d="M0 450 Q 300 350 600 450 T 1200 450" stroke="#1d4ed8" stroke-width="1" fill="none"
                opacity="0.07" />
            <path d="M0 500 Q 300 400 600 500 T 1200 500" stroke="#1d4ed8" stroke-width="0.5" fill="none"
                opacity="0.05" />
        </svg>
    </div>

    <!-- Content Wrapper (Centered) -->
    <div class="relative z-10 w-full max-w-lg">

        <!-- Form Card -->
        <div class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-8 shadow-2xl">

            <!-- Logo Uang -->
            <div class="flex flex-col items-center mb-6">

                <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase">Form Input</p>
                <h2 class="text-blue-800 text-2xl font-bold mt-1">Tambah Tabungan Baru</h2>
            </div>

            <form id="formSaving" action="/tabungan/tambah" method="POST" class="space-y-5">

                <!-- Aktivitas (Readonly) -->
                <div>
                    <label class="block text-blue-700 text-xs font-semibold tracking-widest uppercase mb-2">
                        Aktivitas
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 0 2-2h2a2 2 0 0 0 2 2" />
                            </svg>
                        </div>
                        <input type="text" name="aktivitas" value="Pemasukan" readonly
                            class="w-full pl-11 pr-4 py-3 bg-blue-50 border border-blue-200 rounded-xl text-blue-600 text-sm font-medium cursor-not-allowed focus:outline-none" />
                    </div>
                    <p class="text-blue-400 text-xs mt-1.5">Jenis aktivitas tidak dapat diubah.</p>
                </div>

                <!-- Nominal -->
                <div>
                    <label class="block text-blue-700 text-xs font-semibold tracking-widest uppercase mb-2">
                        Nominal <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="text-blue-400 text-sm font-semibold">Rp</span>
                        </div>
                        <input type="number" name="nominal" id="nominal" min="1" placeholder="0" required
                            class="w-full pl-11 pr-4 py-3 bg-white border border-blue-200 rounded-xl text-blue-800 text-sm font-medium placeholder-blue-200 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all" />
                    </div>
                    <p class="text-blue-400 text-xs mt-1.5">Masukkan jumlah tabungan dalam Rupiah.</p>
                </div>

                <!-- Pesan -->
                <div>
                    <label class="block text-blue-700 text-xs font-semibold tracking-widest uppercase mb-2">
                        Pesan <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <div class="absolute top-3.5 left-0 pl-4 flex items-start pointer-events-none">
                            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                            </svg>
                        </div>
                        <textarea name="pesan" id="pesan" rows="3"
                            placeholder="Tulis catatan atau pesan untuk tabungan ini..."
                            class="w-full pl-11 pr-4 py-3 bg-white border border-blue-200 rounded-xl text-blue-800 text-sm font-medium placeholder-blue-200 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all resize-none"></textarea>
                    </div>
                    <p class="text-blue-400 text-xs mt-1.5">Tambahkan catatan, misalnya: "Gaji bulan April".</p>
                </div>

                <!-- Divider -->
                <div class="border-t border-blue-100 pt-2"></div>

                <!-- Submit Button -->
                <button type="button" onclick="openModal()"
                    class="w-full bg-blue-700 text-white font-semibold text-sm px-6 py-3.5 rounded-xl hover:bg-blue-800 active:scale-95 transition-all shadow-md flex items-center justify-center gap-2 group">
                    <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor"
                        stroke-width="2.5" viewBox="0 0 24 24">
                        <path d="M12 5v14M5 12h14" />
                    </svg>
                    Tambah Tabungan
                </button>

                <!-- Kembali ke Dashboard -->
                <a href="/dashboard"
                    class="w-full flex items-center justify-center gap-2 border border-blue-300 text-blue-700 font-medium text-sm px-6 py-3 rounded-xl hover:bg-blue-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M19 12H5M12 5l-7 7 7 7" />
                    </svg>
                    Kembali ke Dashboard
                </a>

            </form>
        </div>

    </div>
</main>

<div id="overlay" onclick="closeModal()"
    class="fixed inset-0 bg-blue-950/40 z-40 opacity-0 pointer-events-none transition-opacity duration-300 hidden">
</div>

<div id="sheet"
    class="fixed bottom-0 left-0 right-0 bg-white rounded-t-2xl z-50 translate-y-full transition-transform duration-300 ease-out p-6 max-w-lg mx-auto hidden">
    <div class="w-9 h-1 bg-blue-200 rounded-full mx-auto mb-5"></div>
    <h3 class="text-blue-800 font-bold text-base mb-1">Konfirmasi Tabungan</h3>
    <p class="text-blue-300 text-xs mb-5">Pastikan data berikut sudah benar.</p>
    <div class="bg-blue-50 rounded-xl p-4 border border-blue-100 space-y-3 mb-5">
        <div class="flex justify-between text-sm"><span class="text-blue-400">Aktivitas</span><span
                class="text-blue-800 font-bold text-sm">Pemasukan</span></div>
        <div class="flex justify-between text-sm border-t border-blue-100 pt-3"><span
                class="text-blue-400">Nominal</span><span id="modal-nominal"
                class="text-blue-800 font-bold text-base"></span></div>
        <div class="flex justify-between text-sm border-t border-blue-100 pt-3"><span
                class="text-blue-400">Pesan</span><span id="modal-pesan"
                class="text-blue-600 italic text-right max-w-xs"></span></div>
    </div>

    <div class="space-y-3">
        <button onclick="doSubmit(event)"
            class="w-full bg-blue-700 text-white font-semibold text-sm px-6 py-3.5 rounded-xl hover:bg-blue-800 active:scale-95 transition-all shadow-md flex items-center justify-center gap-2 group">Konfirmasi
            &
            Simpan</button>
        <button onclick="closeModal()"
            class="w-full flex items-center justify-center gap-2 border border-blue-300 text-blue-700 font-medium text-sm px-6 py-3 rounded-xl hover:bg-blue-50 transition-colors">Batal,
            Periksa Lagi</button>
    </div>
</div>

<script src="/js/addSaving.js"></script>