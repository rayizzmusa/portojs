<main class="pt-16 min-h-screen bg-white flex items-center justify-center px-6 relative overflow-hidden">

    <!-- Transparent SVG Background -->
    <div class="absolute inset-0">
        <svg viewBox="0 0 1200 700" xmlns="http://www.w3.org/2000/svg" class="w-full h-full"
            preserveAspectRatio="xMidYMid slice">
            <defs>
                <pattern id="dots" width="40" height="40" patternUnits="userSpaceOnUse">
                    <circle cx="20" cy="20" r="1" fill="#1d4ed8" opacity="0.15" />
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dots)" />
            <circle cx="100" cy="120" r="180" fill="#1d4ed8" opacity="0.04" />
            <circle cx="1100" cy="580" r="220" fill="#1d4ed8" opacity="0.04" />
            <circle cx="1050" cy="100" r="120" fill="#1d4ed8" opacity="0.05" />
            <circle cx="200" cy="600" r="150" fill="#1d4ed8" opacity="0.03" />
            <path d="M0 400 Q 300 300 600 400 T 1200 400" stroke="#1d4ed8" stroke-width="1" fill="none" opacity="0.1" />
            <path d="M0 450 Q 300 350 600 450 T 1200 450" stroke="#1d4ed8" stroke-width="1" fill="none"
                opacity="0.07" />
            <path d="M0 500 Q 300 400 600 500 T 1200 500" stroke="#1d4ed8" stroke-width="0.5" fill="none"
                opacity="0.05" />
        </svg>
    </div>

    <!-- Horizontal Content Wrapper -->
    <div class="relative z-10 w-full max-w-5xl flex flex-col lg:flex-row items-stretch gap-6">

        <!-- KIRI: Selamat Datang -->
        <div
            class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-10 w-full lg:w-1/2 text-center lg:text-left shadow-2xl flex flex-col justify-center">

            <!-- Icon -->
            <div
                class="w-16 h-16 bg-blue-700 rounded-2xl flex items-center justify-center mx-auto lg:mx-0 mb-6 shadow-md">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="1.8"
                    viewBox="0 0 24 24">
                    <path d="M3 12l9-9 9 9" />
                    <path d="M9 21V12h6v9" />
                </svg>
            </div>

            <!-- Text -->
            <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-3">Dashboard Aktif</p>
            <h1 class="text-blue-800 text-4xl font-bold leading-tight mb-3">
                Selamat Datang,<br />
                <span class="text-blue-500">
                    <%= userName !=='undefined' ? userName : '' %>
                </span>
            </h1>
            <p class="text-blue-500 text-sm leading-relaxed mb-8">
                Mulai menabung saat ini, supaya bisa segera menikah dengan kekasihmu.
            </p>

            <!-- Buttons -->
            <div class="flex gap-3 justify-center lg:justify-start flex-wrap">
                <button
                    class="bg-blue-700 text-white font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-blue-800 transition-colors shadow">
                    Tambah Tabungan
                </button>
                <button
                    class="border border-blue-300 text-blue-700 font-medium text-sm px-6 py-2.5 rounded-xl hover:bg-blue-50 transition-colors">
                    Lihat Laporan
                </button>
            </div>
        </div>

        <!-- KANAN: Nominal & Tabungan Per Orang -->
        <div class="w-full lg:w-1/2 flex flex-col gap-4 justify-center">

            <!-- Total Tabungan -->
            <div class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-7 shadow-2xl">
                <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-2">Total Tabungan Terkumpul
                </p>
                <p class="text-blue-800 text-4xl font-bold">--</p>
            </div>

            <!-- Per Orang: Rayhan & Syifa -->
            <div class="flex gap-4">
                <!-- Rayhan -->
                <div class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-6 shadow-2xl flex-1">
                    <div class="w-10 h-10 bg-blue-700 bg-opacity-20 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" stroke-width="2"
                            viewBox="0 0 24 24">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                        </svg>
                    </div>
                    <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-1">Rayhan</p>
                    <p class="text-blue-800 text-3xl font-bold">--</p>
                </div>

                <!-- Syifa -->
                <div class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-6 shadow-2xl flex-1">
                    <div class="w-10 h-10 bg-blue-700 bg-opacity-20 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" stroke-width="2"
                            viewBox="0 0 24 24">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                        </svg>
                    </div>
                    <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-1">Syifa</p>
                    <p class="text-blue-800 text-3xl font-bold">--</p>
                </div>
            </div>

            <div class="bg-blue-700 bg-opacity-10 border border-blue-200 rounded-2xl p-7 shadow-2xl">
                <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-4">Notifikasi Terakhir</p>

                <!-- Notifikasi 1 -->
                <div class="flex items-start justify-between gap-4 pb-4 border-b border-blue-100">
                    <div class="flex items-start gap-3">
                        <div
                            class="w-8 h-8 bg-blue-700 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-blue-700" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M12 22c1.1 0 2-.9 2-2H10c0 1.1.9 2 2 2zm6-6V11c0-3.07-1.64-5.64-4.5-6.32V4a1.5 1.5 0 0 0-3 0v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" />
                            </svg>
                        </div>
                        <p class="text-blue-800 text-sm font-medium leading-snug">Rayhan menambahkan tabungan sebesar
                            <span class="text-blue-600 font-semibold">Rp 500.000</span>
                        </p>
                    </div>
                    <p class="text-blue-500 text-xs whitespace-nowrap mt-0.5">23 Apr 2026<br />08:45</p>
                </div>

                <!-- Notifikasi 2 -->
                <div class="flex items-start justify-between gap-4 pt-4">
                    <div class="flex items-start gap-3">
                        <div
                            class="w-8 h-8 bg-blue-700 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-blue-700" fill="none" stroke="currentColor" stroke-width="2"
                                viewBox="0 0 24 24">
                                <path
                                    d="M12 22c1.1 0 2-.9 2-2H10c0 1.1.9 2 2 2zm6-6V11c0-3.07-1.64-5.64-4.5-6.32V4a1.5 1.5 0 0 0-3 0v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" />
                            </svg>
                        </div>
                        <p class="text-blue-800 text-sm font-medium leading-snug">Syifa menambahkan tabungan sebesar
                            <span class="text-blue-600 font-semibold">Rp 300.000</span>
                        </p>
                    </div>
                    <p class="text-blue-500 text-xs whitespace-nowrap mt-0.5">22 Apr 2026<br />19:12</p>
                </div>

                <!-- Tombol -->
                <div class="mt-5">
                    <a href="/notifikasi.html"
                        class="inline-flex items-center gap-2 border border-blue-300 text-blue-700 font-medium text-sm px-5 py-2 rounded-xl hover:bg-blue-50 transition-colors">
                        Lihat Notifikasi
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>

        </div>
    </div>
</main>